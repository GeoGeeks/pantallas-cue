---
// src/layouts/BaseLayout.astro
import SvgSprites from "../components/SvgSprites.astro";
const { title, extraCss = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link rel="stylesheet" href={`${base}/styles/global.css`} />

    {
      Array.isArray(extraCss) &&
        extraCss.map((style) => (
          <link rel="stylesheet" href={`${base}/styles/${style}.css`} />
        ))
    }
  </head>
  <body>
    <SvgSprites />
    <slot />
  </body>
</html>
